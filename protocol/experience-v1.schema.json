    "OfferVerb": {
      "type": "string",
      "enum": [
        "cast",
        "play_land",
        "activate",
        "pass_priority",
        "declare_attackers",
        "declare_blockers",
        "choose",
        "pay",
        "special"
      ]
    },
    "PresentationEvent": {
      "description": "Presentation payloads remain opaque in this certification because the\nmerged adapter emits no semantic presentation events yet. The envelope and\nordering metadata are nevertheless fixed at the wire boundary.",
      "type": "object",
      "properties": {
        "caused_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "from_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
