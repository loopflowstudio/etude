    "LegacyTurnView": {
      "type": "object",
      "properties": {
        "active_player_id": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "agent_player_id": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "phase": {
          "type": "string"
        },
        "step": {
          "type": "string"
        },
        "turn_number": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
