    },
    "ObjectRenderId": {
      "type": "object",
      "properties": {
        "entity": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "incarnation": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "entity",
        "incarnation"
      ]
