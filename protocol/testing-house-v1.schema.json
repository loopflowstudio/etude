    "AdviceRequestIdentity": {
      "additionalProperties": false,
      "description": "The advisor + compute identity a request claims to incorporate.\n\nThe GAM-4 seam: this is the request contract GAM-4's live decision-address\nand retry/compare controls bind to. Mirrors the fixture's pinned\n``StudyIdentity`` -- the source replay and match must match, the advisor id\nmust match the pinned ``model.id``, and the compute id must match the pinned\n``analysis_budget.id``. When GAM-4 publishes the live ``erd1`` address, the\nsame identity flows through ``POST /api/advice`` unchanged.",
      "properties": {
        "advisor_id": {
          "title": "Advisor Id",
          "type": "string"
        },
        "compute_id": {
          "title": "Compute Id",
          "type": "string"
        },
        "match_id": {
          "title": "Match Id",
          "type": "string"
        },
        "source_replay_id": {
          "title": "Source Replay Id",
          "type": "string"
        }
      },
      "required": [
        "source_replay_id",
        "match_id",
        "advisor_id",
        "compute_id"
      ],
      "title": "AdviceRequestIdentity",
      "type": "object"
    },
